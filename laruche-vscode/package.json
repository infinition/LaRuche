{
    "name": "laruche-vscode",
    "displayName": "LaRuche - Local AI Copilot",
    "description": "Local Edge AI Copilot powered by the LAND Protocol. Zero cloud, zero API keys.",
    "version": "0.1.0",
    "publisher": "infinition",
    "repository": {
        "type": "git",
        "url": "https://github.com/infinition/LaRuche"
    },
    "icon": "media/icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Machine Learning",
        "Programming Languages",
        "Other"
    ],
    "keywords": [
        "ai",
        "copilot",
        "local",
        "llm",
        "edge",
        "land-protocol",
        "laruche"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "laruche.ask",
                "title": "Ask LaRuche",
                "icon": "$(comment-discussion)",
                "category": "LaRuche"
            },
            {
                "command": "laruche.explainSelection",
                "title": "Explain Selection",
                "icon": "$(lightbulb)",
                "category": "LaRuche"
            },
            {
                "command": "laruche.refactorSelection",
                "title": "Refactor Selection",
                "icon": "$(edit)",
                "category": "LaRuche"
            },
            {
                "command": "laruche.openChat",
                "title": "Open Chat Panel",
                "icon": "$(comment-discussion)",
                "category": "LaRuche"
            },
            {
                "command": "laruche.showSwarm",
                "title": "Show Swarm Status",
                "icon": "$(server)",
                "category": "LaRuche"
            },
            {
                "command": "laruche.agentEdit",
                "title": "Agent: Edit File",
                "icon": "$(wand)",
                "category": "LaRuche"
            },
            {
                "command": "laruche.undoLastEdit",
                "title": "Agent: Undo Last Edit",
                "icon": "$(discard)",
                "category": "LaRuche"
            },
            {
                "command": "laruche.agentHistory",
                "title": "Agent: Edit History",
                "icon": "$(history)",
                "category": "LaRuche"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "command": "laruche.explainSelection",
                    "when": "editorHasSelection",
                    "group": "laruche@1"
                },
                {
                    "command": "laruche.refactorSelection",
                    "when": "editorHasSelection",
                    "group": "laruche@2"
                },
                {
                    "command": "laruche.agentEdit",
                    "group": "laruche@3"
                }
            ]
        },
        "keybindings": [
            {
                "command": "laruche.agentEdit",
                "key": "ctrl+shift+l",
                "mac": "cmd+shift+l",
                "when": "editorTextFocus"
            }
        ],
        "configuration": {
            "title": "LaRuche",
            "properties": {
                "laruche.nodeUrl": {
                    "type": "string",
                    "default": "",
                    "description": "Direct URL to a LaRuche node (e.g. http://192.168.1.10:8419). Leave empty for auto-discovery."
                },
                "laruche.apiPort": {
                    "type": "number",
                    "default": 8419,
                    "description": "Default API port for LaRuche nodes."
                },
                "laruche.model": {
                    "type": "string",
                    "default": "",
                    "description": "Preferred model name (leave empty for node default)."
                },
                "laruche.agentMode": {
                    "type": "string",
                    "default": "ask",
                    "enum": [
                        "auto",
                        "ask",
                        "readonly"
                    ],
                    "enumDescriptions": [
                        "Apply changes automatically",
                        "Show diff and ask before applying",
                        "Show suggestions without modifying files"
                    ],
                    "description": "Agent edit mode: auto (apply immediately), ask (show diff first), readonly (suggest only)."
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "laruche",
                    "title": "LaRuche",
                    "icon": "$(beaker)"
                }
            ]
        },
        "views": {
            "laruche": [
                {
                    "type": "webview",
                    "id": "laruche.chatView",
                    "name": "Chat"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "webpack",
        "watch": "webpack --watch",
        "package": "webpack --mode production --devtool hidden-source-map",
        "lint": "eslint src --ext ts"
    },
    "devDependencies": {
        "@types/vscode": "^1.85.0",
        "@types/node": "20.x",
        "ts-loader": "^9.5.1",
        "typescript": "^5.3.3",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4"
    }
}